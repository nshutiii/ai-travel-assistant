APP_NAME=AI Travel Assistant
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Local development (SQLite file next to the working directory)
DATABASE_URL=sqlite:///./ai_travel_assistant.db

# Example PostgreSQL URL (install driver; see requirements.txt)
# DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/ai_travel_assistant

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
